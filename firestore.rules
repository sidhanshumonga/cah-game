rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile; admins can read all profiles
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || request.auth.token.email == 'sidhanshumonga28@gmail.com');
      allow create: if request.auth != null && request.auth.uid == uid
                    && request.resource.data.credits <= 50
                    && request.resource.data.admin == false;
      allow update: if request.auth != null && request.auth.uid == uid
                    && (request.resource.data.admin == resource.data.admin || request.auth.token.email == 'sidhanshumonga28@gmail.com')
                    && request.resource.data.credits == resource.data.credits
                    && request.resource.data.packs == resource.data.packs
                    && request.resource.data.upgrades == resource.data.upgrades
                    && request.resource.data.history == resource.data.history;
    }

    // Allow collection group queries on the players subcollection
    match /{path=**}/players/{uid} {
      allow read: if true;
    }

    // Feedback: only the admin can read directly; writes must go through verified API
    match /feedback/{feedbackId} {
      allow create, update, delete: if false;
      allow read: if request.auth != null && request.auth.token.email == 'sidhanshumonga28@gmail.com';
    }

    // Packages: anyone can read; only the admin can write
    match /packages/{packId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'sidhanshumonga28@gmail.com';
    }

    // Purchases: only server-side writes; users can read their own, admin can read all
    match /purchases/{purchaseId} {
      allow create, update, delete: if false;
      allow read: if request.auth != null && (request.auth.token.email == 'sidhanshumonga28@gmail.com' || resource.data.userId == request.auth.uid);
    }

    // Rooms: guests get single rooms, admin lists, host creates/updates settings
    match /rooms/{code} {
      allow get: if true;
      allow list: if request.auth != null && request.auth.token.email == 'sidhanshumonga28@gmail.com';
      allow create: if (request.auth != null && request.resource.data.hostUid == request.auth.uid) ||
                    (request.resource.data.hostUid.matches('.*@guest[.]example[.]com'));
      allow update: if (request.auth != null && resource.data.hostUid == request.auth.uid) ||
                    (resource.data.hostUid.matches('.*@guest[.]example[.]com'));
      allow delete: if (request.auth != null && resource.data.hostUid == request.auth.uid) ||
                    (resource.data.hostUid.matches('.*@guest[.]example[.]com'));

      match /players/{uid} {
        allow read: if true;
        allow write: if (
          // Host can write/manage any player doc in their room
          (request.auth != null && get(/databases/$(database)/documents/rooms/$(code)).data.hostUid == request.auth.uid) ||
          (get(/databases/$(database)/documents/rooms/$(code)).data.hostUid.matches('.*@guest[.]example[.]com')) ||
          // Authenticated user can write their own player doc
          (request.auth != null && request.auth.uid == uid) ||
          // Guest user can write their own doc
          (uid.matches('.*@guest[.]example[.]com'))
        );
      }

      match /chat/{msgId} {
        allow read: if true;
        allow create: if (
          exists(/databases/$(database)/documents/rooms/$(code)/players/$(request.resource.data.uid))
        );
        allow update, delete: if false;
      }

      match /reactions/{reactionId} {
        allow read: if true;
        allow create: if (
          exists(/databases/$(database)/documents/rooms/$(code)/players/$(request.resource.data.uid))
        );
        allow update, delete: if false;
      }

      match /gameState/{doc} {
        allow read: if true;
        allow write: if true;
      }
    }
  }
}
