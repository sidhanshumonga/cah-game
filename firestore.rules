rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile; admins can read all profiles
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || request.auth.token.email == 'sidhanshumonga28@gmail.com');
      allow create: if request.auth != null && request.auth.uid == uid
                    && request.resource.data.credits <= 50
                    && request.resource.data.admin == false;
      allow update: if request.auth != null && request.auth.uid == uid
                    && (request.resource.data.admin == resource.data.admin || request.auth.token.email == 'sidhanshumonga28@gmail.com')
                    && request.resource.data.credits == resource.data.credits
                    && request.resource.data.packs == resource.data.packs
                    && request.resource.data.upgrades == resource.data.upgrades
                    && request.resource.data.history == resource.data.history;
      allow delete: if false;
    }

    // Feedback: anyone can submit feedback; admin can read
    match /feedback/{feedbackId} {
      allow create: if true;
      allow read: if request.auth != null && request.auth.token.email == 'sidhanshumonga28@gmail.com';
    }

    // Packages: anyone can read; only the admin can write
    match /packages/{packId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'sidhanshumonga28@gmail.com';
    }

    // Purchases: authenticated users can write/read their own purchases; admin role can read all
    match /purchases/{purchaseId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (request.auth.token.email == 'sidhanshumonga28@gmail.com' || resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }

    // Rooms: anyone can read and write to support guest sessions
    match /rooms/{code} {
      allow read, write: if true;

      match /players/{uid} {
        allow read, write: if true;
      }

      match /chat/{msgId} {
        allow read, write: if true;
      }

      match /reactions/{reactionId} {
        allow read, write: if true;
      }

      match /gameState/{doc} {
        allow read, write: if true;
      }
    }
  }
}
