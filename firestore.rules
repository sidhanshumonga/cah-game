rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Feedback: anyone can submit feedback
    match /feedback/{feedbackId} {
      allow create: if true;
    }

    // Packages: anyone can read; only the admin can write
    match /packages/{packId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'sidhanshumonga28@gmail.com';
    }

    // Purchases: authenticated users can write/read their own purchases; admin email can read all
    match /purchases/{purchaseId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.token.email == 'sidhanshumonga28@gmail.com');
      allow update, delete: if false;
    }

    // Rooms: anyone can read and write to support guest sessions
    match /rooms/{code} {
      allow read, write: if true;

      match /players/{uid} {
        allow read, write: if true;
      }

      match /chat/{msgId} {
        allow read, write: if true;
      }

      match /reactions/{reactionId} {
        allow read, write: if true;
      }

      match /gameState/{doc} {
        allow read, write: if true;
      }
    }
  }
}
